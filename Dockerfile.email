FROM golang:1.22-alpine AS builder

WORKDIR /src

RUN apk add --no-cache ca-certificates git

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/email-worker ./cmd/email-worker

FROM gcr.io/distroless/base-debian12:nonroot

WORKDIR /

COPY --from=builder /out/email-worker /email-worker

USER nonroot:nonroot

ENTRYPOINT ["/email-worker"]
